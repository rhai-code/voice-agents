# ---------- Backend (WebSocket Server) ----------
FROM registry.access.redhat.com/ubi9/python-312:latest

USER root
WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app

# Install Python dependencies
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# Copy app code
COPY ws_server.py /app/ws_server.py
COPY src/ /app/src/

# Voice clone reference files
COPY belinda.wav /app/belinda.wav
COPY belinda.txt /app/belinda.txt
COPY mike.wav /app/mike.wav
COPY mike.txt /app/mike.txt

USER 1001
EXPOSE 8765

CMD ["python", "ws_server.py"]

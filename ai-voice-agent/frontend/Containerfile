# ---------- Frontend Build ----------
FROM registry.access.redhat.com/ubi9/nodejs-22 AS frontend-builder

USER root
WORKDIR /app

# Copy only package files first to leverage Docker cache
COPY package*.json ./

RUN npm ci --no-audit --no-fund

# Now copy the rest of the frontend code
COPY . ./

ENV NODE_OPTIONS=--max-old-space-size=512
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build
RUN test -d out

# ---------- Static Runtime ----------
FROM registry.access.redhat.com/ubi9/nginx-120

USER root
COPY --from=frontend-builder /app/out/ /usr/share/nginx/html/
COPY nginx.conf /etc/nginx/nginx.conf
RUN test -f /usr/share/nginx/html/index.html
RUN chgrp -R 0 /usr/share/nginx/html \
    && chmod -R g=u /usr/share/nginx/html \
    && mkdir -p /var/cache/nginx /var/run /var/log/nginx \
    && chgrp -R 0 /var/cache/nginx /var/run /var/log/nginx \
    && chmod -R g=u /var/cache/nginx /var/run /var/log/nginx

USER 1001
EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
